generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  firstName        String
  lastName         String
  email            String   @unique
  password         String
  role             String
  registrationYear String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Family {
  id          String   @id @default(cuid())
  name        String
  pere        String
  mere        String
  memberCount Int
  year        String
  createdAt   DateTime @default(now())
}

model Member {
  id               String   @id @default(cuid())
  firstName        String
  lastName         String
  email            String?
  phone            String?
  joinDate         String?
  baptismDate      String?
  address          String?
  pastor           String?
  churchElder      String?
  isCouncil        Boolean  @default(false)
  isDeacon         Boolean  @default(false)
  isDeaconess      Boolean  @default(false)
  position         String?
  responsibilities String?
  year             String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isBaptized       Boolean  @default(false)
}

model Choir {
  id          String   @id @default(cuid())
  name        String
  leaderName  String
  memberNames String[] @default([])
  year        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id         String   @id @default(cuid())
  name       String
  leaderName String
  activities String?
  year       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Finance {
  id          String   @id @default(cuid())
  type        String
  category    String
  amount      Float
  date        String
  description String?
  year        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inventory {
  id          String   @id @default(cuid())
  type        String
  name        String
  count       Int?
  description String?
  issuedTo    String?
  date        String
  year        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String
  date      String
  published Boolean  @default(false)
  fileName  String?
  fileData  String?
  year      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemConfig {
  id                  String   @id @default("global")
  blockLogin          Boolean  @default(false)
  blockRegister       Boolean  @default(false)
  availableYears      String[] @default(["2024-2025"])
  blockedYears        String[] @default([])
  restrictNewAccounts Boolean  @default(false)
  restrictOldAccounts Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model Report {
  id        String   @id @default(cuid())
  title     String
  period    String
  value     String
  status    String   @default("Verified")
  type      String
  pdfUrl    String?
  year      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
